APP_ENV=local
SERVICE_NAME=wave-cast-api
HTTP_ADDR=:8080
HTTP_ALLOWED_ORIGINS=*

STORAGE_DRIVER=memory
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=wave_cast

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=wave-cast
KAFKA_TOPIC_VOICE_EVENTS=voice.events
KAFKA_TOPIC_VOICE_JOBS=voice.jobs
KAFKA_TOPIC_ANALYTICS=voice.analytics.events

LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_TOKEN_TTL_SECONDS=3600

CENTRIFUGO_URL=http://localhost:8000
CENTRIFUGO_API_KEY=dev_centrifugo_api_key
CENTRIFUGO_TOKEN_SECRET=dev_centrifugo_secret
CENTRIFUGO_CONNECTION_TOKEN_TTL_SECONDS=3600
CENTRIFUGO_SUBSCRIPTION_TOKEN_TTL_SECONDS=600

MEDIA_PASSIVE_ENABLED=true
MEDIA_PASSIVE_MODE=origin
MEDIA_ORIGIN_BASE_URL=http://localhost:3333
MEDIA_CDN_BASE_URL=

LISTENER_STREAM_ENABLED=true
LISTENER_STREAM_PROTOCOL=ll_hls
LISTENER_STREAM_LATENCY_PROFILE=low_latency
LISTENER_STREAM_SEGMENT_DURATION_MS=1000
LISTENER_STREAM_PART_DURATION_MS=250
LISTENER_STREAM_TARGET_LATENCY_MS=3000

LISTENER_HEARTBEAT_INTERVAL_SECONDS=30
LISTENER_SESSION_TIMEOUT_SECONDS=90

RECORDING_ENABLED=true
RECORDING_AUTO_START=false
RECORDING_RETENTION_ENABLED=true
RECORDING_RETENTION_DAYS=30

S3_ENDPOINT=http://minio:9000
S3_BUCKET=wave-cast-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_RECORDINGS_PREFIX=recordings
S3_PRESIGNED_URL_TTL_SECONDS=900
