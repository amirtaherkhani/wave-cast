APP_ENV=production
SERVICE_NAME=wave-cast-api
HTTP_ADDR=:8080
HTTP_ALLOWED_ORIGINS=https://app.example.com

STORAGE_DRIVER=mongo
MONGO_URI=mongodb://mongo-0.mongo:27017,mongo-1.mongo:27017
MONGO_DATABASE=wave_cast

REDIS_ADDR=redis:6379
REDIS_ENABLED=true
REDIS_PASSWORD=change_me
REDIS_DB=0

KAFKA_ENABLED=true
KAFKA_BROKERS=kafka-0:9092,kafka-1:9092,kafka-2:9092
KAFKA_CLIENT_ID=wave-cast
KAFKA_TOPIC_VOICE_EVENTS=voice.events
KAFKA_TOPIC_VOICE_JOBS=voice.jobs
KAFKA_TOPIC_ANALYTICS=voice.analytics.events

LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=change_me
LIVEKIT_API_SECRET=change_me

CENTRIFUGO_URL=https://realtime.example.com
CENTRIFUGO_API_KEY=change_me
CENTRIFUGO_TOKEN_SECRET=change_me

MEDIA_PASSIVE_ENABLED=true
MEDIA_PASSIVE_MODE=cdn
MEDIA_ORIGIN_BASE_URL=https://origin-media.example.com
MEDIA_CDN_BASE_URL=https://cdn.example.com

RECORDING_ENABLED=true
RECORDING_AUTO_START=false
RECORDING_RETENTION_ENABLED=true
RECORDING_RETENTION_DAYS=30

S3_BUCKET=voice-prod-media
S3_REGION=eu-central-1
S3_RECORDINGS_PREFIX=recordings

ASYNC_WORKER_ENABLED=true
ASYNC_WORKER_CONCURRENCY=10
ASYNC_JOB_MAX_ATTEMPTS=5
ASYNC_JOB_VISIBILITY_TIMEOUT_SECONDS=300
ASYNC_JOB_RETRY_BASE_DELAY_SECONDS=5
ASYNC_JOB_RETRY_MAX_DELAY_SECONDS=300
ASYNC_JOB_LOCK_TTL_SECONDS=300
ASYNC_JOB_DEAD_LETTER_ENABLED=true

ASYNC_SCHEDULER_ENABLED=true
ASYNC_EXPIRE_LISTENER_SESSIONS_INTERVAL_SECONDS=30
ASYNC_EXPIRE_RECORDINGS_INTERVAL_SECONDS=3600
ASYNC_SYNC_ROOM_COUNTS_INTERVAL_SECONDS=60
